rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /organizations/{orgId} {
      allow read, write: if request.auth != null;
    }
    match /assets/{assetId} {
      allow read, write: if request.auth != null;
    }
    match /violations/{violationId} {
      allow read, write: if request.auth != null;
    }
    match /dmca_notices/{noticeId} {
      allow read, write: if request.auth != null;
    }
  }
}
